NODE_ENV=development
PORT=4000

# Public/frontend coordination
WEB_APP_URL=http://localhost:5173
PUBLIC_SITE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://examnovaai.onrender.com

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/examnova

# Auth and sessions
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_TOKEN_COOKIE_NAME=examnova_refresh
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=lax

# OTP and password reset
OTP_TTL_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
RESET_PASSWORD_TTL_MINUTES=15

# Mail / OTP delivery
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=ExamNova AI

# Payments
RAZORPAY_KEY_ID=rzp_test_example
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret

# AI provider
AI_PROVIDER=openai
AI_API_KEY=replace_with_ai_provider_key
AI_MODEL=gpt-5.4

# Upload and storage
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
FILE_STORAGE_DISK=local
FILE_STORAGE_BUCKET=examnova-assets
# On Render, prefer a persistent-disk mount such as /var/data/examnova-uploads
LOCAL_UPLOAD_DIR=uploads

# Logging and infra
LOG_LEVEL=info
TRUST_PROXY=false
REQUEST_ID_HEADER=x-request-id
